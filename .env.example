# === LLM Provider 선택 ===
# google(기본, Gemini) / openai / openrouter
LLM_PROVIDER=google

# --- Google Gemini 사용 시 (임베딩은 openai가 아닌 이상 항상 이 키를 씁니다) ---
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CHAT_MODEL=gemini-2.5-flash
GOOGLE_EMBED_MODEL=models/gemini-embedding-001

# --- OpenAI 사용 시 (LLM_PROVIDER=openai일 때만 필요) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- OpenRouter 사용 시 (LLM_PROVIDER=openrouter일 때만 필요, 임베딩은 위 GOOGLE_API_KEY로 대체됨) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=qwen/qwen3-coder:free

# === 뉴스/웹 검색 Tool ===
TAVILY_API_KEY=your_tavily_api_key_here

# === 로그 레벨 ===
LOG_LEVEL=INFO
